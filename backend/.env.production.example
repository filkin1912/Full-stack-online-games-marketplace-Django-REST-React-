# Copy to ".env.production" for local Docker builds, or set the same variables
# in Cloud Run / GitHub Actions from repository secrets (do not commit real values).
#
# Repository secrets (example names) → map to these env var names in deployment:
#   SECRET_KEY, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET,
#   OPENAI_API_KEY_ORIGINAL → use as AI_API_KEY (Django reads AI_API_KEY only).

# ==========================
# Security
# ==========================
SECRET_KEY=replace-with-strong-secret
DEBUG=False
ALLOWED_HOSTS=your-service.run.app,your-custom-domain.com

SESSION_COOKIE_NAME=sessionid

# ==========================
# CORS / CSRF (your React / Firebase URLs)
# ==========================
CORS_ALLOWED_ORIGINS=https://your-frontend.web.app,https://your-frontend.firebaseapp.com
CSRF_TRUSTED_ORIGINS=https://your-backend.run.app,https://your-frontend.web.app

# ==========================
# Cloudinary (media)
# ==========================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ==========================
# Database (PostgreSQL)
# ==========================
DB_NAME=examdb
DB_USER=examuser
DB_PASSWORD=exampass
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=
DB_CHANNEL_BINDING=

# ==========================
# Chatbot (OpenRouter / OpenAI-compatible)
# ==========================
AI_API_KEY=your-openrouter-or-openai-key
