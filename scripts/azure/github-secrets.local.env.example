# Copy to github-secrets.local.env (ignored by git), fill values, then:
#   .\push-github-secrets.ps1
#
# Lines: NAME=value  or  NAME="value with spaces"
# Empty lines and # comments are skipped.

AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_ACR_NAME=
AZURE_CONTAINER_APP_BACKEND=
AZURE_CONTAINER_APP_FRONTEND=

SECRET_KEY=
DATABASE_URL=
ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AI_API_KEY=
